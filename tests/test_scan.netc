link "math_library.netc";

init() {
    text my_string = "Hello NetC";
    dnum my_int = 100;
    cnum my_float = 3.14159;
    flag is_running = true;
    is_running = false;

    if (my_int == 100) {
        forward(my_string);
    } else {
        yield my_int;
    }

}

# Testing Functions and Loops
network process_data(dnum input_val, flag status) {
    iterate (dnum i = 0; i < 10; i=i+i) {
        forward(i);
    }

    until (status == true) {
        feed input_val;
        status = false;
    }
}

